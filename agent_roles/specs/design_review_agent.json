  "memory_scope": ["design decision memory", "component memory", "research memory", "brand memory"],
  "escalation_triggers": ["accessibility risk", "brand conflict", "user harm risk", "missing research basis"],
  "evaluation_metrics": ["issue detection quality", "designer acceptance rate", "handoff rework reduction"],
