  "responsibilities": ["design comparison", "component consistency check", "accessibility flagging", "critique drafting"],
  "inputs": ["design artifacts", "design system docs", "research memory", "brand guidelines"],
  "outputs": ["review notes", "consistency flags", "accessibility issues", "critique questions"],
